# .github/workflows/ci.yml — generated by calango new
name: CI

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main, develop]

env:
  PYTHON_VERSION: "3.12"
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:

  quality:
    name: Lint & Types
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5
      - uses: astral-sh/setup-uv@v6
        with:
          enable-cache: true
      - name: Lint (Ruff)
        run: uv run ruff check .
      - name: Format check (Ruff)
        run: uv run ruff format --check .

  security:
    name: Security (SAST + SCA)
    runs-on: ubuntu-latest
    needs: quality
    steps:
      - uses: actions/checkout@v5
      - uses: astral-sh/setup-uv@v6
        with:
          enable-cache: true
      - name: SCA — pip-audit (block on known CVEs with a fix)
        run: |
          uv export --format requirements-txt --no-emit-workspace --no-hashes --no-dev \
            | grep -v '^-e' \
            | uv run pip-audit -r /dev/stdin
      - name: Install Opengrep (pinned for reproducible scans)
        run: |
          curl -fsSL https://raw.githubusercontent.com/opengrep/opengrep/main/install.sh | bash -s -- -v v1.22.0
          echo "$HOME/.opengrep/cli/latest" >> "$GITHUB_PATH"
      - name: SAST — Opengrep (block on findings)
        run: opengrep scan --config security/opengrep/ --error app/

  test-unit:
    name: Unit Tests
    runs-on: ubuntu-latest
    needs: quality
    steps:
      - uses: actions/checkout@v5
      - uses: astral-sh/setup-uv@v6
        with:
          enable-cache: true
      - name: Run unit tests
        run: uv run pytest tests/unit/ --cov=app --cov-fail-under=80 -x

  test-integration:
    name: Integration Tests
    runs-on: ubuntu-latest
    needs: test-unit
    services:
      postgres:
        image: postgres:16-alpine
        env:
          POSTGRES_DB: {{ project_name }}_test
          POSTGRES_USER: {{ project_name }}
          POSTGRES_PASSWORD: {{ project_name }}
        options: >-
          --health-cmd pg_isready
          --health-interval 5s
          --health-timeout 5s
          --health-retries 5
      redis:
        image: redis:7-alpine
        options: >-
          --health-cmd "redis-cli ping"
          --health-interval 5s
    steps:
      - uses: actions/checkout@v5
      - uses: astral-sh/setup-uv@v6
        with:
          enable-cache: true
      - name: Run integration tests
        run: uv run pytest tests/integration/ --cov=app --cov-append -x
        env:
          DATABASE__URL: postgresql+asyncpg://{{ project_name }}:{{ project_name }}@localhost:5432/{{ project_name }}_test
          REDIS__URL: redis://localhost:6379/0
          SECURITY__SECRET_KEY: ci-test-secret-key

  build:
    name: Docker Build
    runs-on: ubuntu-latest
    needs: [test-integration]
    steps:
      - uses: actions/checkout@v5
      - uses: docker/setup-buildx-action@v3
      - name: Build production image
        uses: docker/build-push-action@v5
        with:
          context: .
          target: production
          push: false
          tags: {{ project_name }}:${{ '{{' }} github.sha {{ '}}' }}
          cache-from: type=gha
          cache-to: type=gha,mode=max
